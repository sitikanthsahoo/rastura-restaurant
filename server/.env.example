# Backend Environment Variables
# Copy this file to .env and fill in your values

# Port the server runs on
PORT=5000

# MongoDB Atlas connection string (get from MongoDB Atlas dashboard)
MONGODB_URI=mongodb+srv://<username>:<password>@yourcluster.mongodb.net/rastura?retryWrites=true&w=majority

# JWT Secret — use any long random string (keep this secret!)
JWT_SECRET=replace_with_a_long_random_secret_string
